# Copy this to .env and fill in your values
# ============================================================
# LOCAL LLM (required for reasoning engine)
# ============================================================
# Ollama (recommended):  start with `ollama run llama3.1:8b`
# LM Studio:             set base_url to http://localhost:1234/v1
# vLLM / LocalAI:        point to your server's OpenAI-compat endpoint
LLM_ENABLED=true
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b

# ============================================================
# BROKER APIs
# ============================================================
TASTYTRADE_USERNAME=your_username
TASTYTRADE_PASSWORD=your_password
IB_ACCOUNT=DU123456
IB_ACCOUNT_ID=DU123456
IB_PORT=7497
POLYGON_API_KEY=your_polygon_key
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret

# ============================================================
# DATABASE
# ============================================================
DB_PASSWORD=your_db_password

# ============================================================
# NOTIFICATIONS
# ============================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
